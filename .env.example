# Runtime mode: paper (default), demo, live
GOLDBOT_MODE=paper
GOLDBOT_SYMBOL=XAUUSD
GOLDBOT_TIMEFRAME=M15
GOLDBOT_BARS=300
GOLDBOT_LOOP_SECONDS=60

# MT5 credentials
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=

# OpenAI filter
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GOLDBOT_AI_ENABLED=true
GOLDBOT_AI_TIMEOUT_SECONDS=8
GOLDBOT_AI_RETRIES=1
GOLDBOT_AI_FAIL_BEHAVIOR=reject

# Risk limits
GOLDBOT_RISK_PER_TRADE_PCT=0.5
GOLDBOT_MAX_RISK_PER_TRADE_PCT=1.0
GOLDBOT_MAX_DAILY_LOSS_PCT=2.0
GOLDBOT_MAX_CONCURRENT_POSITIONS=1
GOLDBOT_MAX_CONSECUTIVE_LOSSES=3
GOLDBOT_COOLDOWN_MINUTES=60
GOLDBOT_DUPLICATE_WINDOW_SECONDS=120

# Optional alerts/journal
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
GOLDBOT_CSV_PATH=trades.csv
GOLDBOT_SQLITE_PATH=
